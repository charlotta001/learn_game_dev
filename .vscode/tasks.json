{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build",
                "-G", "MinGW Makefiles",
                "-DCMAKE_C_COMPILER=E:/msys64/ucrt64/bin/gcc.exe",
                "-DCMAKE_CXX_COMPILER=E:/msys64/ucrt64/bin/g++.exe",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "Generate build files dengan CMake + w64devkit"
        },
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--config", "Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "detail": "Build project (Ctrl+Shift+B)"
        },
        {
            "label": "CMake Configure & Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build",
                "-G", "MinGW Makefiles",
                "-DCMAKE_C_COMPILER=C:/raylib/w64devkit/bin/gcc.exe",
                "-DCMAKE_CXX_COMPILER=C:/raylib/w64devkit/bin/g++.exe",
                "-DCMAKE_BUILD_TYPE=Debug",
                "&&",
                "cmake",
                "--build", "${workspaceFolder}/build"
            ],
            "group": "build",
            "problemMatcher": "$gcc",
            "detail": "Configure lalu build sekaligus (pakai ini pertama kali)"
        }
    ]
}